# Copy to .env and fill in. `.env` is gitignored.

# Google AI Studio API key — enable billing for more than 20 req/day
GOOGLE_API_KEY=

# Slack bot token with chat:write — invite the bot to your channel first
SLACK_BOT_TOKEN=xoxb-

# Slack channel ID (the one starting with C...) where the weekly digest posts
SLACK_CHANNEL_ID=
